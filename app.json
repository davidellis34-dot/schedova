{
  "expo": {
    "name": "Schedova",
    "slug": "schedova",
    "scheme": "schedova",
    "version": "1.1.6",
    "orientation": "default",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "notification": {
      "icon": "./assets/images/notification-icon.png",
      "color": "#0F766E"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "18",
      "bundleIdentifier": "com.davidellis34.schedova",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundColor": "#0F172A",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png"
      },
      "package": "com.davidellis34.schedova",
      "versionCode": 16
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0F766E",
          "defaultChannel": "client-messages"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "536a4221-4d72-4d63-9df3-c80d327931cd"
      }
    }
  }
}
